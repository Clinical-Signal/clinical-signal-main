# =============================================================================
# Clinical Signal — environment template (copy to `.env` at repo root)
# Next.js (`apps/web`) loads from the repo root when using `pnpm --filter web dev`.
# =============================================================================

# --- Database (required for apps/web lib/env.ts) ---
DATABASE_URL=postgresql://clinical_signal:change_me_dev_only@localhost:5432/clinical_signal

# Postgres (docker-compose service defaults)
POSTGRES_USER=clinical_signal
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=clinical_signal
POSTGRES_PORT=5432

# --- Auth ---
# At least 32 random bytes in production. Generate with: openssl rand -base64 48
AUTH_SECRET=dev_only_change_me_minimum_32_chars_long
SESSION_IDLE_MINUTES=15
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
HIBP_FAIL_OPEN=false

# pgcrypto symmetric key for patient name / DOB columns (dev must match seed SQL)
PHI_ENCRYPTION_KEY=dev_only_change_me_phi_crypt_key

# --- Analysis engine ---
ANALYSIS_ENGINE_URL=http://localhost:8000
ENGINE_JWT_SECRET=dev_only_change_me_engine_jwt_secret_min_32

# --- Anthropic (required; BAA-covered account in production) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Public app URL + SMTP (patient intake magic-link emails) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Docker Compose: Mailpit UI at http://localhost:8025
SMTP_SERVER=mailpit
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASSWORD=dev
EMAIL_FROM_ADDRESS=intake@example.com

# --- Intake module (PRD §1.3) ---
REDIS_URL=redis://localhost:6379
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ASSEMBLYAI_API_KEY=
INTAKE_TOKEN_TTL_DAYS=7
INTAKE_TOKEN_RATE_LIMIT_PER_MIN=10
WHISPER_SERVICE_URL=http://whisper:9000
TEXTRACT_REGION=

# --- Auth stub (Phase 0; swap for Supabase in production) ---
SUPABASE_DEV_USER_ID=00000000-0000-0000-0000-000000000099
