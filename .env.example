# Postgres (used by docker-compose)
POSTGRES_USER=clinical_signal
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=clinical_signal
POSTGRES_PORT=5432

# Auth
# At least 32 random bytes in production. Generate with: openssl rand -base64 48
AUTH_SECRET=dev_only_change_me_minimum_32_chars_long
SESSION_IDLE_MINUTES=15
# The tenant new practitioner signups are attached to in dev. Matches the row
# seeded by database/migrations/0001_auth.sql.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# Set HIBP_FAIL_OPEN=true only in offline dev — production must fail closed.
HIBP_FAIL_OPEN=false

# pgcrypto symmetric key for patient name / DOB columns. Dev default must
# match the value baked into database/migrations/0003_seed_dev.sql so the
# seeded rows decrypt cleanly. In production this comes from KMS.
PHI_ENCRYPTION_KEY=dev_only_change_me_phi_crypt_key

# Anthropic Claude API. Required for lab extraction. Without it, uploaded
# records will be marked failed with a clear error. Get a key from
# https://console.anthropic.com — production must use a BAA-covered account.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
