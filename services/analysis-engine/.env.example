DATABASE_URL=postgresql://clinical_signal:change_me_dev_only@localhost:5432/clinical_signal
# ANTHROPIC_API_KEY=

# Shared HS256 secret used by the analysis engine to verify the JWTs
# the web tier signs (apps/web/lib/{records,protocols}.ts via
# packages/core/src/tenancy/jwt.ts). MUST match the web tier's value.
ENGINE_JWT_SECRET=dev_only_change_me_engine_jwt_secret_min_32

# Google service-account key for the Drive watcher (Phase 5) and the
# scripts/verify_drive_access.py setup-verification script. The path
# must point to a JSON key file inside infrastructure/secrets/, which
# is .gitignored. Path is relative to the repo root unless absolute.
GOOGLE_APPLICATION_CREDENTIALS=infrastructure/secrets/google-service-account.json
