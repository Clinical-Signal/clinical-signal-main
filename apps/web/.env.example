DATABASE_URL=postgresql://clinical_signal:change_me_dev_only@localhost:5432/clinical_signal
ANALYSIS_ENGINE_URL=http://localhost:8000
# Shared HS256 secret for engine JWTs. The web tier signs requests to
# the engine with this; the engine verifies with the same value.
# Production: source from KMS / a managed secret store. Rotate with a
# brief overlap window — JWTs are 5-minute TTL.
ENGINE_JWT_SECRET=dev_only_change_me_engine_jwt_secret_min_32
