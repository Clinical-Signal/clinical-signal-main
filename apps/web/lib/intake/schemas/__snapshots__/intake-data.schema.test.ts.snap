exports[`intake-data.schema > matches AiConfirmationSlot.shape snapshot 1`] = `
{
  "at": {
    "optional": "ZodString",
  },
  "by": {
    "optional": "ZodString",
  },
  "confirmed": "ZodBoolean",
  "value": "ZodUnknown",
}
`;

