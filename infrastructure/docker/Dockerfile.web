FROM node:20-alpine

WORKDIR /app

# The build context is the repo root (see docker-compose.yml). Internal
# TS packages (@cs/core, @cs/db) live at /packages and are resolved by
# apps/web/tsconfig.json paths (../../packages/{core,db}/src). They must
# be present at npm-install/typecheck/runtime, hence the COPY below.

COPY apps/web/package.json apps/web/package-lock.json* ./
RUN npm install

# Place packages/ at the parent of WORKDIR so `../..` from /app/* lands
# inside `/packages/...` matching the tsconfig path alias. In dev these
# files are also mounted as a volume (read-only) so edits hot-reload
# without a rebuild.
COPY packages /packages

# apps/web/tsconfig.json extends ../../tsconfig.base.json — from /app that
# resolves to /tsconfig.base.json (repo root), not a path under /app.
COPY tsconfig.base.json /tsconfig.base.json

COPY apps/web/ ./

EXPOSE 3000

CMD ["npm", "run", "dev"]
