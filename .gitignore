# Env
.env
.env.local
.env.*.local
!.env.example

# Secrets — service account keys, signing certs, anything credential-shaped
infrastructure/secrets/

# Node
node_modules/
.next/
out/
dist/
*.log
npm-debug.log*
.pnpm-debug.log*
.turbo/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editors
.DS_Store
.idea/
.vscode/
*.swp

# Docker
.docker/

# Build artifacts
coverage/
*.tsbuildinfo

# Claude Code local state
.claude/

# Extracted Dr. Laura mentorship knowledge (third-party IP; regenerated
# via scripts/ingest_knowledge.py). Do not commit the extracted content.
database/seed/knowledge/*.jsonl

# Raw Dr. Laura source material staged for ingestion — same IP concern.
# Cert PDFs are an exception (committed at database/seed/dr-laura-drive/
# certification-materials/). Other staging dirs are re-populated from
# Drive per docs/SLACK-EXTRACTION-RECIPE.md and the exhaust plan.
# .gitkeep files are preserved so the staging dir structure persists in git.
database/seed/dr-laura-slack/raw-export/*
!database/seed/dr-laura-slack/raw-export/.gitkeep
database/seed/dr-laura-drive/peptide-workshop/*
!database/seed/dr-laura-drive/peptide-workshop/.gitkeep
database/seed/dr-laura-drive/fellowship-curriculum/*
!database/seed/dr-laura-drive/fellowship-curriculum/.gitkeep

# Office / LibreOffice lock files (auto-created when a doc is open)
.~lock.*#
~$*

# Working business artifacts at repo root (brand kit, cost analyses,
# checklists, etc.) — not codebase. If a doc needs to enter the repo,
# add it explicitly via `git add -f path/to/doc.docx`.
/*.docx
/*.xlsx

# Stray zero-byte files at repo root from typoed shell commands
/git
/rm

.vercel
